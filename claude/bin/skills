#!/usr/bin/env ruby
# frozen_string_literal: true
#
# Bundler-flavored skill manager for Claude Code.
#   bin/skills install   sync to Skillfile.lock (default)
#   bin/skills update    re-resolve refs to latest, rewrite lock
#   bin/skills update <repo>   update one source
#   bin/skills clean     drop cache + symlinks no longer in the lock
#
# Each git source pins per "origin": an autodiscovered (repo, root) pins as a
# unit under one `revision`; an explicit `skill` pins individually under `pins`.
# `install` resolves only new origins and leaves locked ones untouched; `update`
# re-resolves them. One worktree per (repo, revision) lets a single repo supply
# skills at several commits at once.

require "fileutils"
require "set"
require "yaml"

ROOT       = File.expand_path("..", __dir__)
SKILLFILE  = File.join(ROOT, "Skillfile")
LOCKFILE   = File.join(ROOT, "Skillfile.lock")
CACHE_DIR  = File.join(ROOT, "cache")
REPOS_DIR  = File.join(CACHE_DIR, "repos")
TREES_DIR  = File.join(CACHE_DIR, "trees")
OUTPUT_DIR = File.join(CACHE_DIR, "skills")

class Entry
  attr_reader :skills, :auto_discover
  def initialize(auto_discover:)
    @skills = []
    @auto_discover = auto_discover
  end
  def add_skill(name)
    @skills << name
  end
  def explicit_skills
    @skills.sort
  end
end

class GitEntry < Entry
  attr_reader :repo, :ref, :root
  def initialize(repo:, ref:, root: "skills", auto_discover:)
    super(auto_discover: auto_discover)
    @repo, @ref, @root = repo, ref, root
  end
  def kind; :git; end
  def lock_key; ["git", @repo, @root]; end
  def cache_dir; File.join(REPOS_DIR, @repo.tr("/", "_")); end
  def url; "https://github.com/#{@repo}.git"; end
  def worktree_dir(sha); File.join(TREES_DIR, "#{@repo.tr("/", "_")}_#{sha[0, 12]}"); end
  def skill_path(name, sha); File.join(worktree_dir(sha), @root, name); end
  def label; "#{@repo}#"; end
  def discovered_skills(sha)
    Dir.glob(File.join(worktree_dir(sha), @root, "*")).select { |d|
      File.directory?(d) && File.exist?(File.join(d, "SKILL.md"))
    }.map { |d| File.basename(d) }.sort
  end
end

class DirectoryEntry < Entry
  attr_reader :relative_path, :dir
  def initialize(relative_path:, dir:, auto_discover:)
    super(auto_discover: auto_discover)
    @relative_path = relative_path
    @dir = dir
  end
  def kind; :directory; end
  def lock_key; ["directory", @relative_path]; end
  def skill_path(name); File.join(@dir, name); end
  def label; "#{@relative_path}/"; end
  def discovered_skills
    Dir.glob(File.join(@dir, "*")).select { |d|
      File.directory?(d) && File.exist?(File.join(d, "SKILL.md"))
    }.map { |d| File.basename(d) }.sort
  end
end

class Skillfile
  attr_reader :entries
  def initialize
    @entries = []
    @current = nil
  end
  def source(repo = nil, ref: nil, root: "skills", path: nil, &block)
    if path
      raise "`source path: ...` does not take ref:" if ref
      raise "`source path: ...` does not take a positional repo" if repo
      abs = File.expand_path(path, File.dirname(SKILLFILE))
      entry = DirectoryEntry.new(relative_path: path, dir: abs, auto_discover: !block_given?)
    else
      raise "`source` requires either a positional <repo> or path:" unless repo
      entry = GitEntry.new(repo: repo, ref: ref || "origin/HEAD", root: root, auto_discover: !block_given?)
    end
    add_entry(entry, &block)
  end
  def skill(name)
    raise "`skill #{name.inspect}` must be inside a `source` block" unless @current
    @current.add_skill(name)
  end
  def self.load(path)
    sf = new
    sf.instance_eval(File.read(path), path)
    sf
  end
  private
  def add_entry(entry)
    @current = entry
    yield if block_given?
    @current = nil
    @entries << entry
  end
end

class Lockfile
  def initialize(data = nil)
    @data = data || {"entries" => []}
    @data["entries"] ||= []
  end
  def self.load(path)
    return new unless File.exist?(path)
    new(YAML.load_file(path) || {})
  end
  # Identity of a stored record, mirroring Entry#lock_key. A git source is keyed
  # on (repo, root) — not repo alone — so the same repo can be cherry-picked
  # from multiple subdirs without the entries clobbering each other.
  def self.record_key(e)
    e["kind"] == "git" ? ["git", e["repo"], e["root"]] : ["directory", e["path"]]
  end
  # Skill names a record contributes, whichever pin granularity it uses: an
  # autodiscovered root lists them under "skills" (one shared "revision"),
  # an explicit source under "pins" (a revision per skill).
  def self.record_skills(e)
    e["skills"] || (e["pins"] ? e["pins"].keys : [])
  end
  def entries
    @data["entries"]
  end
  def find(entry)
    @data["entries"].find { |e| Lockfile.record_key(e) == entry.lock_key }
  end
  def upsert(entry, fields)
    @data["entries"].reject! { |e| Lockfile.record_key(e) == entry.lock_key }
    rec = {"kind" => entry.kind.to_s}
    if entry.kind == :git
      rec["repo"] = entry.repo
      rec["ref"] = entry.ref
      rec["root"] = entry.root
    else
      rec["path"] = entry.relative_path
    end
    rec.merge!(fields)
    @data["entries"] << rec
    sort!
  end
  def prune(active_keys)
    @data["entries"].select! { |e| active_keys.include?(Lockfile.record_key(e)) }
  end
  def write(path)
    File.write(path, YAML.dump(@data))
  end
  private
  def sort!
    @data["entries"].sort_by! { |e| Lockfile.record_key(e) }
  end
end

class Runner
  def initialize(dry_run: false)
    abort "no Skillfile at #{SKILLFILE}" unless File.exist?(SKILLFILE)
    @sf = Skillfile.load(SKILLFILE)
    @lock = Lockfile.load(LOCKFILE)
    @dry_run = dry_run
    @added = 0
    @removed = 0
    puts "Running in dry-run mode; no changes will be written." if @dry_run
  end

  def install
    sync_all(update_filter: nil)
  end

  def update(*repos)
    sync_all(update_filter: repos.empty? ? :all : Set.new(repos))
  end

  def clean
    locked_skills = Set.new
    locked_repos = Set.new
    locked_trees = Set.new
    @lock.entries.each do |e|
      locked_skills.merge(Lockfile.record_skills(e))
      next unless e["kind"] == "git"
      slug = e["repo"].tr("/", "_")
      locked_repos << slug
      tree_shas(e).each { |sha| locked_trees << "#{slug}_#{sha[0, 12]}" }
    end

    removed = 0
    removed += prune_dir(OUTPUT_DIR, "skills") { |name| locked_skills.include?(name) }
    removed += prune_dir(TREES_DIR, "trees") { |name| locked_trees.include?(name) }
    removed += prune_dir(REPOS_DIR, "repos") { |name| locked_repos.include?(name) }
    if Dir.exist?(REPOS_DIR)
      Dir.children(REPOS_DIR).each do |slug|
        system("git", "-C", File.join(REPOS_DIR, slug), "worktree", "prune",
               out: File::NULL, err: File::NULL)
      end
    end

    suffix = @dry_run ? " (dry run)" : ""
    if removed.zero?
      puts "Nothing to clean#{suffix}."
    else
      puts "Cleaned #{removed} item(s)#{suffix}."
    end
  end

  def tree_shas(e)
    e["pins"] ? e["pins"].values : [e["revision"]].compact
  end

  def prune_dir(dir, label)
    return 0 unless Dir.exist?(dir)
    removed = 0
    Dir.children(dir).sort.each do |name|
      next if yield(name)
      path = File.join(dir, name)
      puts "  removing   #{label}/#{name}"
      if File.symlink?(path) || File.file?(path)
        File.unlink(path) unless @dry_run
      else
        FileUtils.rm_rf(path) unless @dry_run
      end
      removed += 1
    end
    removed
  end

  private

  def sync_all(update_filter:)
    FileUtils.mkdir_p(REPOS_DIR)

    @sf.entries.each do |entry|
      mode = pick_mode(entry, update_filter)
      sync_entry(entry, mode: mode)
    end

    active_keys = Set.new(@sf.entries.map(&:lock_key))
    @lock.entries.each do |e|
      next if active_keys.include?(Lockfile.record_key(e))
      label = e["kind"] == "git" ? "#{e["repo"]}#" : "#{e["path"]}/"
      log_diff(label, Lockfile.record_skills(e), [])
    end
    @lock.prune(active_keys)
    @lock.write(LOCKFILE) unless @dry_run
    build_output
    print_summary
  end

  def pick_mode(entry, update_filter)
    return :install if update_filter.nil?
    return :update if update_filter == :all
    entry.kind == :git && update_filter.include?(entry.repo) ? :update : :install
  end

  def sync_entry(entry, mode:)
    locked = @lock.find(entry)
    if entry.kind == :git
      sync_git(entry, locked, mode)
    else
      sync_directory(entry, locked, mode)
    end
  end

  def sync_git(entry, locked, mode)
    ensure_clone(entry)
    # A root change yields a different lock_key, so `find` returns nil (a fresh
    # source) rather than a stale match — only ref drift forces a re-resolve.
    ref_changed = locked && locked["ref"] != entry.ref
    if entry.auto_discover
      sync_git_root(entry, locked, mode, ref_changed)
    else
      sync_git_skills(entry, locked, mode, ref_changed)
    end
  end

  # Autodiscovery: the whole (repo, root) is one origin pinned to a single
  # revision; its skill set is whatever exists there at that revision.
  def sync_git_root(entry, locked, mode, ref_changed)
    old_skills = (locked && locked["skills"]) || []
    if mode == :install && locked && locked["revision"] && !ref_changed
      sha = locked["revision"]
      ensure_commit(entry, sha)
      puts "Using #{entry.repo} @ #{sha[0, 8]} (#{entry.root})"
    else
      sha = resolve_latest(entry)
      report_resolve(locked && locked["revision"], sha)
    end
    ensure_worktree(entry, sha)
    new_skills = entry.discovered_skills(sha)
    validate_skills!(entry, new_skills.map { |n| [n, sha] })
    log_diff(entry.label, old_skills, new_skills)
    @lock.upsert(entry, {"revision" => sha, "skills" => new_skills.sort})
  end

  # Explicit skills: each listed skill is its own origin with its own pinned
  # revision, so `install` resolves only newly-added skills and leaves the ones
  # already locked untouched — even when they share a repo at another revision.
  def sync_git_skills(entry, locked, mode, ref_changed)
    old_pins = (locked && locked["pins"]) || {}
    latest = nil
    pins = {}
    entry.explicit_skills.each do |name|
      if mode == :install && old_pins[name] && !ref_changed
        pins[name] = old_pins[name]
      else
        latest ||= resolve_latest(entry)
        pins[name] = latest
      end
    end
    if latest
      report_resolve(nil, latest)
    else
      puts "Using #{entry.repo} (#{entry.root})"
    end
    pins.values.uniq.each { |sha| ensure_commit(entry, sha); ensure_worktree(entry, sha) }
    validate_skills!(entry, pins.to_a)
    log_diff(entry.label, old_pins.keys, pins.keys)
    @lock.upsert(entry, {"pins" => pins.sort.to_h})
  end

  def sync_directory(entry, locked, mode)
    old_skills = (locked && locked["skills"]) || []
    new_skills = entry.auto_discover ? entry.discovered_skills : entry.explicit_skills
    puts "#{locked ? "Using" : "Refreshing"} #{entry.relative_path}/"
    validate_skills!(entry, new_skills.map { |n| [n, nil] })
    log_diff(entry.label, old_skills, new_skills)
    @lock.upsert(entry, {"skills" => new_skills.sort})
  end

  # name_shas is a list of [name, sha] (sha nil for local dirs).
  def validate_skills!(entry, name_shas)
    missing = name_shas.reject do |name, sha|
      target = sha ? entry.skill_path(name, sha) : entry.skill_path(name)
      File.directory?(target) && File.exist?(File.join(target, "SKILL.md"))
    end
    return if missing.empty?
    abort "missing SKILL.md for " +
          missing.map { |n, s| "'#{entry.label}#{n}'#{s ? " at #{s[0, 8]}" : ""}" }.join(", ")
  end

  def log_diff(label, old, new)
    added = new - old
    removed = old - new
    added.each   { |s| puts "  installing '#{label}#{s}'" }
    removed.each { |s| puts "  removing   '#{label}#{s}'" }
    @added += added.size
    @removed += removed.size
  end

  def ensure_clone(entry)
    return if Dir.exist?(File.join(entry.cache_dir, ".git"))
    run("git", "clone", "--quiet", entry.url, entry.cache_dir)
  end

  def fetch(entry)
    run("git", "-C", entry.cache_dir, "fetch", "--quiet", "--tags", "origin")
  end

  def commit_present?(entry, sha)
    system("git", "-C", entry.cache_dir, "cat-file", "-e", "#{sha}^{commit}",
           out: File::NULL, err: File::NULL)
  end

  def ensure_commit(entry, sha)
    fetch(entry) unless commit_present?(entry, sha)
  end

  def resolve_latest(entry)
    puts "Fetching #{entry.repo} @ #{entry.ref}"
    fetch(entry)
    sha = `git -C #{esc entry.cache_dir} rev-parse #{esc entry.ref}^{commit}`.strip
    abort "couldn't resolve #{entry.ref} in #{entry.repo}" if sha.empty?
    sha
  end

  # One worktree per (repo, revision): symlinks resolve lazily against a stable
  # checkout, so a repo can supply skills at several commits simultaneously.
  def ensure_worktree(entry, sha)
    dir = entry.worktree_dir(sha)
    return if Dir.exist?(dir)
    FileUtils.mkdir_p(TREES_DIR)
    system("git", "-C", entry.cache_dir, "worktree", "prune", out: File::NULL, err: File::NULL)
    run("git", "-C", entry.cache_dir, "worktree", "add", "--quiet", "--detach", dir, sha)
  end

  def report_resolve(old_sha, sha)
    if old_sha == sha
      puts "  up-to-date @ #{sha[0, 8]}"
    elsif old_sha
      puts "  #{old_sha[0, 8]} → #{sha[0, 8]}"
    else
      puts "  @ #{sha[0, 8]}"
    end
  end

  def build_output
    FileUtils.mkdir_p(OUTPUT_DIR) unless @dry_run
    seen = {}

    @sf.entries.each do |entry|
      locked = @lock.find(entry)
      next unless locked
      skill_targets(entry, locked).each do |name, target|
        unless File.directory?(target) && File.exist?(File.join(target, "SKILL.md"))
          warn "warning: #{entry.label}#{name} has no SKILL.md at #{target}"
          next
        end
        collide!(seen, name, target)
        link = File.join(OUTPUT_DIR, name)
        if File.symlink?(link)
          next if File.readlink(link) == target
          File.unlink(link) unless @dry_run
        elsif File.exist?(link)
          warn "warning: #{link} exists but is not a symlink; leaving alone"
          next
        end
        File.symlink(target, link) unless @dry_run
      end
    end
  end

  # [name, absolute target] for each skill a locked record installs, resolving
  # the per-skill worktree path for git sources.
  def skill_targets(entry, locked)
    if entry.kind == :git && locked["pins"]
      locked["pins"].map { |name, sha| [name, entry.skill_path(name, sha)] }
    elsif entry.kind == :git
      sha = locked["revision"]
      (locked["skills"] || []).map { |name| [name, entry.skill_path(name, sha)] }
    else
      (locked["skills"] || []).map { |name| [name, entry.skill_path(name)] }
    end
  end

  def collide!(seen, name, target)
    if seen[name]
      abort "skill name collision on '#{name}':\n  #{seen[name]}\n  #{target}"
    end
    seen[name] = target
  end

  def print_summary
    total = @lock.entries.inject(0) { |sum, e| sum + Lockfile.record_skills(e).size }
    suffix = @dry_run ? " (dry run)" : ""
    if @added.zero? && @removed.zero?
      puts "#{total} skill(s) installed, no changes#{suffix}."
    else
      puts "#{total} skill(s) installed (#{@added} added, #{@removed} removed)#{suffix}."
    end
  end

  def run(*cmd)
    system(*cmd) or abort "command failed: #{cmd.join(' ')}"
  end

  def esc(s)
    "'#{s.gsub("'", "'\\\\''")}'"
  end
end

dry_run = ARGV.include?("--dry-run")
argv = ARGV.reject { |a| a == "--dry-run" }
cmd, *args = argv
case cmd
when nil, "install" then Runner.new(dry_run: dry_run).install
when "update"       then Runner.new(dry_run: dry_run).update(*args)
when "clean"        then Runner.new(dry_run: dry_run).clean
else
  warn "usage: skills [install|update [<repo> ...]|clean] [--dry-run]"
  exit 1
end
